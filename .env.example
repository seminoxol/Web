# ─────────────────────────────────────────────
#  PCI Glass — Email Configuration Template
#  Copy this file to .env and fill in the values
#  DO NOT commit .env to git
# ─────────────────────────────────────────────

# ── Option A (recommended on Render): Resend ──
# Sign up at https://resend.com — free tier works for quote forms.
# Verify your domain (pciglass.ca) then use:
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=PCI Glass <quotes@pciglass.ca>

# ── Option B: Gmail SMTP ──
# The Gmail address that sends emails
EMAIL_USER=your_gmail@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to get one:
#   1. Go to myaccount.google.com
#   2. Security → 2-Step Verification (enable if not already)
#   3. Security → App passwords
#   4. Select app: Mail | Device: Windows Computer
#   5. Click Generate — copy the 16-character password here (spaces optional)
EMAIL_PASS=your_16_char_app_password

# Where quote request emails are delivered
EMAIL_TO=Pciglass@gmail.com

# Optional: Discord/Slack webhook for instant quote alerts (backup if email fails)
# QUOTE_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Port the server listens on
PORT=8080
